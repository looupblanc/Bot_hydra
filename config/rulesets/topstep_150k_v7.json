{
  "schema": "hydra_topstep_150k_ruleset_v7",
  "as_of_date": "2026-07-12",
  "account_size_usd": 150000,
  "deployment_ticket_blocking_statuses": ["CONFLICT", "ASSUMED"],
  "rules": [
    {
      "id": "R1",
      "statement": "Trading Combine net profit target is USD 9,000 and there is no mission-imposed evaluation timeout for deployment qualification.",
      "source": "https://help.topstep.com/en/articles/8284197-trading-combine-parameters",
      "date": "2026-07-12",
      "status": "WEB_SOURCED",
      "parameters": {"profit_target_usd": 9000.0}
    },
    {
      "id": "R2",
      "statement": "MLL distance is USD 4,500; touch is an immediate breach on realized plus unrealized PnL; EOD-balance and intraday-live-equity trailing interpretations coexist until human TopstepX verification.",
      "source": "https://help.topstep.com/en/articles/8284204-what-is-the-maximum-loss-limit",
      "date": "2026-07-12",
      "status": "CONFLICT",
      "parameters": {
        "distance_usd": 4500.0,
        "default_variant": "eod_level_rt_breach",
        "sensitivity_variant": "intraday_hwm",
        "legacy_default_alias": "EOD_REALIZED_BALANCE",
        "legacy_sensitivity_alias": "INTRADAY_LIVE_EQUITY_HWM_CONSERVATIVE_MFE_FIRST",
        "touch_is_breach": true,
        "floor_never_falls": true,
        "combine_floor_lock_usd": 150000.0
      }
    },
    {
      "id": "R3",
      "statement": "The optional USD 3,000 DLL liquidates and blocks the current session but does not itself fail the account; research reports both enabled and disabled scenarios.",
      "source": "https://help.topstep.com/en/articles/10490293-daily-loss-limit-in-the-trading-combine-and-express-funded-account",
      "date": "2026-07-12",
      "status": "WEB_SOURCED",
      "parameters": {"optional_dll_usd": 3000.0, "account_failure": false}
    },
    {
      "id": "R4",
      "statement": "The Combine best day must be at or below 50% of total profit; excess inflates the required target rather than immediately failing the account.",
      "source": "https://help.topstep.com/en/articles/8284208-consistency-at-topstep",
      "date": "2026-07-12",
      "status": "WEB_SOURCED",
      "parameters": {"best_day_max_fraction": 0.5, "breach_action": "TARGET_INFLATION"}
    },
    {
      "id": "R5",
      "statement": "The 150K maximum position is 15 mini-equivalent contracts; micros count at ten per mini.",
      "source": "https://help.topstep.com/en/articles/8284197-trading-combine-parameters",
      "date": "2026-07-12",
      "status": "WEB_SOURCED",
      "parameters": {"max_mini_equivalent": 15, "max_micros": 150, "micro_to_mini": 10}
    },
    {
      "id": "R6",
      "statement": "The simulator currently uses a two-trading-day minimum, but a human must verify the active TopstepX account before any deployment ticket.",
      "source": "https://help.topstep.com/en/articles/8284197-trading-combine-parameters",
      "date": "2026-07-12",
      "status": "ASSUMED",
      "parameters": {"minimum_trading_days": 2}
    },
    {
      "id": "R7",
      "statement": "Combine waiting time has a monthly subscription cost that must enter downstream sizing value; exact purchase-path price requires human verification before deployment.",
      "source": "https://help.topstep.com/en/articles/14289835-topstep-pricing-and-payment-questions",
      "date": "2026-07-12",
      "status": "ASSUMED",
      "parameters": {"contract_reference_monthly_usd": 149.0, "pricing_must_be_human_verified": true}
    },
    {
      "id": "R8",
      "statement": "A 150K XFA begins at USD 0 with floor USD -4,500; the trailing floor locks at USD 0.",
      "source": "https://help.topstep.com/en/articles/8284204-what-is-the-maximum-loss-limit",
      "date": "2026-07-12",
      "status": "WEB_SOURCED",
      "parameters": {"starting_balance_usd": 0.0, "starting_floor_usd": -4500.0, "floor_lock_usd": 0.0}
    },
    {
      "id": "R9",
      "statement": "XFA Standard requires five USD 150+ winning days and positive net profit since the prior payout; 150K payout cap is USD 5,000 per request.",
      "source": "https://help.topstep.com/en/articles/8284233-topstep-payout-policy",
      "date": "2026-07-12",
      "status": "WEB_SOURCED",
      "parameters": {"winning_days": 5, "winning_day_min_usd": 150.0, "payout_cap_usd": 5000.0}
    },
    {
      "id": "R10",
      "statement": "After the first XFA payout the MLL floor is permanently USD 0, leaving only retained profit as buffer.",
      "source": "https://help.topstep.com/en/articles/8284233-topstep-payout-policy",
      "date": "2026-07-12",
      "status": "WEB_SOURCED",
      "parameters": {"post_first_payout_floor_usd": 0.0}
    },
    {
      "id": "R11",
      "statement": "XFA Consistency uses three traded days and a largest-day fraction in the contract-specified 30%-40% conflict band; simulator sensitivity uses 40% pending human verification.",
      "source": "https://help.topstep.com/en/articles/8284208-consistency-at-topstep",
      "date": "2026-07-12",
      "status": "CONFLICT",
      "parameters": {"minimum_traded_days": 3, "simulated_largest_day_max_fraction": 0.4, "conflict_range": [0.3, 0.4]}
    },
    {
      "id": "R12",
      "statement": "The trader profit split is 90/10 for the post-12-January-2026 path represented by this project.",
      "source": "https://help.topstep.com/en/articles/8284233-topstep-payout-policy",
      "date": "2026-07-12",
      "status": "WEB_SOURCED",
      "parameters": {"trader_fraction": 0.9, "effective_path_date": "2026-01-12"}
    },
    {
      "id": "R13",
      "statement": "TopstepX API automation is permitted only from the trader's supervised personal device; this remote research server has zero broker or order capability.",
      "source": "https://help.topstep.com/en/articles/11187768-topstepx-api-access",
      "date": "2026-07-12",
      "status": "WEB_SOURCED",
      "parameters": {"research_server_order_capability": false, "remote_execution_allowed": false}
    },
    {
      "id": "R14",
      "statement": "HFT, latency arbitrage, SIM-fill exploitation, impossible tight brackets, queue exploitation and account stacking are prohibited; loss of positive edge under 2x slippage is SIM_EXPLOIT.",
      "source": "https://help.topstep.com/en/articles/10305426-prohibited-trading-strategies-at-topstep",
      "date": "2026-07-12",
      "status": "WEB_SOURCED",
      "parameters": {"slippage_stress_multiplier": 2.0, "nonpositive_edge_status": "SIM_EXPLOIT"}
    },
    {
      "id": "R15",
      "statement": "Any later automated CME order flow must be tagged as automated under CME Rule 575/Tag 1028; HYDRA V7 itself submits no orders.",
      "source": "https://www.cmegroup.com/notices/market-regulation/2019/12/RA1914-5.pdf",
      "date": "2026-07-12",
      "status": "WEB_SOURCED",
      "parameters": {"fix_tag": 1028, "automated_indicator": "N", "hydra_order_count": 0}
    },
    {
      "id": "R16",
      "statement": "Topstep trading days are attributed in America/Chicago from 17:00 CT; payout winning days lock at 16:00 CT, independently of the mandatory 15:10 CT position flatten.",
      "source": "https://help.topstep.com/en/articles/8284233-topstep-payout-policy",
      "date": "2026-07-12",
      "status": "WEB_SOURCED",
      "parameters": {
        "timezone": "America/Chicago",
        "trading_day_start_local": "17:00",
        "session_flatten_local": "15:10",
        "winning_day_lock_local": "16:00",
        "dst_aware": true
      }
    }
  ]
}
